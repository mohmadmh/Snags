<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <title>لعبة الدودة المطورة</title>
    <style>
        body { 
            display: flex; flex-direction: column; justify-content: center; align-items: center; 
            height: 100vh; margin: 0; background: radial-gradient(#2c3e50, #000); 
            color: white; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; overflow: hidden;
        }
        .ui { margin-bottom: 10px; text-align: center; }
        canvas { 
            border: 10px solid #34495e; border-radius: 8px;
            box-shadow: 0 0 30px rgba(46, 204, 113, 0.3); 
            background-color: #1a1a1a;
        }
        .stats-container { display: flex; gap: 20px; font-size: 1.2rem; }
        .level-up { color: #f1c40f; font-weight: bold; animation: blink 0.5s infinite; }
        @keyframes blink { 0% { opacity: 1; } 50% { opacity: 0; } 100% { opacity: 1; } }
    </style>
</head>
<body>

    <div class="ui">
        <h1>🐍 تحدي الدودة السريعة</h1>
        <div class="stats-container">
            <p>النقاط: <span id="score" style="color: #2ecc71;">0</span></p>
            <p>المستوى: <span id="level" style="color: #f1c40f;">1</span></p>
            <p>أعلى نتيجة: <span id="highScore" style="color: #e74c3c;">0</span></p>
        </div>
    </div>

    <canvas id="snakeGame" width="400" height="400"></canvas>

    <script>
        const canvas = document.getElementById("snakeGame");
        const ctx = canvas.getContext("2d");
        const scoreElement = document.getElementById("score");
        const levelElement = document.getElementById("level");
        const highScoreElement = document.getElementById("highScore");

        const box = 20;
        let snake = [{ x: 10 * box, y: 10 * box }];
        let food = getRandomFood();
        let score = 0;
        let level = 1;
        let gameSpeed = 150; 
        let d = "RIGHT";
        let nextD = "RIGHT"; 
        let highScore = localStorage.getItem("snakeHighScore") || 0;
        highScoreElement.innerText = highScore;

        // تحسين التحكم (منع الدودة من عكس اتجاهها فجأة وتصادمها مع نفسها)
        document.addEventListener("keydown", e => {
            if(e.keyCode == 37 && d != "RIGHT") nextD = "LEFT";
            else if(e.keyCode == 38 && d != "DOWN") nextD = "UP";
            else if(e.keyCode == 39 && d != "LEFT") nextD = "RIGHT";
            else if(e.keyCode == 40 && d != "UP") nextD = "DOWN";
        });

        function getRandomFood() {
            return {
                x: Math.floor(Math.random() * 19 + 1) * box,
                y: Math.floor(Math.random() * 19 + 1) * box
            };
        }

        function draw() {
            d = nextD;
            // مسح الخلفية بتأثير ضبابي خفيف للحركة
            ctx.fillStyle = "rgba(26, 26, 26, 0.8)";
            ctx.fillRect(0, 0, canvas.width, canvas.height);

            for(let i = 0; i < snake.length; i++) {
                // تدرج لوني لجسم الدودة
                ctx.fillStyle = (i == 0) ? "#2ecc71" : "#27ae60";
                ctx.shadowBlur = (i == 0) ? 15 : 0;
                ctx.shadowColor = "#2ecc71";
                ctx.fillRect(snake[i].x, snake[i].y, box-2, box-2);
                ctx.shadowBlur = 0;
            }

            // رسم الطعام بتوهج
            ctx.fillStyle = "#e74c3c";
            ctx.shadowBlur = 10;
            ctx.shadowColor = "#e74c3c";
            ctx.beginPath();
            ctx.arc(food.x + box/2, food.y + box/2, box/2.5, 0, Math.PI * 2);
            ctx.fill();
            ctx.shadowBlur = 0;

            let snakeX = snake[0].x;
            let snakeY = snake[0].y;

            if( d == "LEFT") snakeX -= box;
            if( d == "UP") snakeY -= box;
            if( d == "RIGHT") snakeX += box;
            if( d == "DOWN") snakeY += box;

            // منطق الأكل وزيادة الصعوبة
            if(snakeX == food.x && snakeY == food.y) {
                score++;
                if(score % 5 == 0) { // زيادة المستوى كل 5 نقاط
                    level++;
                    gameSpeed = Math.max(50, gameSpeed - 15); // زيادة السرعة
                    clearInterval(game);
                    game = setInterval(draw, gameSpeed);
                }
                scoreElement.innerText = score;
                levelElement.innerText = level;
                food = getRandomFood();
            } else {
                snake.pop();
            }

            let newHead = { x: snakeX, y: snakeY };

            // منطق الخسارة (الاصطدام بالجدران أو الجسم)
            if(snakeX < 0 || snakeX >= canvas.width || snakeY < 0 || snakeY >= canvas.height || collision(newHead, snake)) {
                if(score > highScore) {
                    localStorage.setItem("snakeHighScore", score);
                }
                alert(`انتهت اللعبة! \nنقاطك: ${score} \nالمستوى: ${level}`);
                location.reload();
            }

            snake.unshift(newHead);
        }

        function collision(head, array) {
            for(let i = 0; i < array.length; i++) {
                if(head.x == array[i].x && head.y == array[i].y) return true;
            }
            return false;
        }

        let game = setInterval(draw, gameSpeed);
    </script>
</body>
</html>
